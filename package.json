{
  "name": "create-next-workspace",
  "version": "16.0.1",
  "description": "CLI for bootstrapping Next.js workspaces",
  "main": "index.js",
  "bin": {
    "create-next-workspace": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run copy-templates",
    "copy-templates": "cpy \"src/core/templates/**/*\" dist/templates --dot",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepublishOnly": "npm run build && cpy README.npm.md README.md"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.8.0",
    "cpy-cli": "^7.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
